season_levels <- c(
  "1. Early (Jul-Aug)",
  "2. Mid (Sep-Oct)",
  "3. Late (Nov-Dec)"
)

get_df <- reactive({
  if (input$disease == "DENV-3") {
    df_denv3_season %>% filter(Season_Part == input$season)
  } else {
    df_tau_ready %>% filter(Season_Part == input$season)
  }
})

get_result <- reactive({
  df <- get_df()

  if (input$disease == "DENV-3") {
    calculate_denv3_tau(df, input$t_window)
  } else {
    calculate_new_tau(df, input$t_window)
  }
})

get_tau_value <- function(res) {
  res$`Clustering Ratio (Tau)`[[1]]
}

get_local_counts <- function(res) {
  c(
    linked = res$`Neighborhood Pairs (Both Positive)`[[1]],
    unlinked = res$`Neighborhood Pairs (At least 1 Negative)`[[1]]
  )
}

get_global_counts <- function(res) {
  c(
    linked = res$`Citywide Pairs (Both Positive)`[[1]],
    unlinked = res$`Citywide Pairs (At least 1 Negative)`[[1]]
  )
}

get_local_odds <- function(res) {
  res$`Neighborhood Odds`[[1]]
}

get_global_odds <- function(res) {
  res$`Citywide Odds`[[1]]
}
