```{r}
renderPlotly({
  windows <- seq(7, 60, by = 7)

  df_d3  <- df_denv3_season %>% filter(Season_Part == input$season)
  df_abv <- df_tau_ready %>% filter(Season_Part == input$season)

  tau_d3 <- sapply(windows, function(w) {
    calculate_denv3_tau(df_d3, w)$`Clustering Ratio (Tau)`[[1]]
  })

  tau_abv <- sapply(windows, function(w) {
    calculate_new_tau(df_abv, w)$`Clustering Ratio (Tau)`[[1]]
  })

  df_plot <- data.frame(
    window = rep(windows, 2),
    tau = c(tau_d3, tau_abv),
    Outcome = rep(c("DENV-3", "ABV"), each = length(windows))
  )

  p <- ggplot(
    df_plot,
    aes(
      x = window,
      y = tau,
      color = Outcome,
      group = Outcome,
      text = paste0(
        "Outcome: ", Outcome,
        "<br>Window: ", window,
        "<br>\u03C4: ", sprintf('%.2f', tau)
      )
    )
  ) +
    geom_line(linewidth = 1.2, na.rm = TRUE) +
    geom_point(size = 2.8, na.rm = TRUE) +
    geom_vline(
      xintercept = input$t_window,
      linetype = "dashed",
      color = "gray50"
    ) +
    scale_color_manual(
      values = c("DENV-3" = "#2f69b1", "ABV" = "#63b84a")
    ) +
    scale_x_continuous(breaks = windows) +
    labs(
      x = "Time Window (days)",
      y = "\u03C4 (Clustering Ratio)",
      color = NULL
    ) +
    theme_minimal(base_size = 12) +
    theme(
      legend.position = "bottom",
      panel.grid.minor = element_blank(),
      axis.title = element_text(size = 10),
      axis.text = element_text(size = 9),
      legend.text = element_text(size = 9),
      plot.margin = margin(6, 6, 0, 6)
    )

  ggplotly(p, tooltip = "text", height = 260) %>%
    config(displayModeBar = FALSE)
})

```

