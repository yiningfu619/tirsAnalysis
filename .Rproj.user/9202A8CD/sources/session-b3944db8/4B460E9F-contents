```{r}
renderUI({
  res <- get_result()
  tau <- get_tau_value(res)

  label <- if (is.na(tau)) {
    "Not enough valid pairs"
  } else if (tau > 1) {
    "Clustering detected"
  } else if (tau == 1) {
    "No clustering difference"
  } else {
    "Weak clustering"
  }

  detail <- if (is.na(tau)) {
    "The current selection does not have enough non-self, time-valid pairs to estimate &tau;."
  } else if (tau > 1) {
    "Cases are more likely to be linked within the same cluster than across the city."
  } else {
    "Local clustering is not stronger than the citywide baseline."
